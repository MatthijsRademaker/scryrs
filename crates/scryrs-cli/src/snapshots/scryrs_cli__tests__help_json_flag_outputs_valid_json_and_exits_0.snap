{"binary":"scryrs","commands":[{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"}],"description":"Discover and analyze knowledge hotspots in a repository","name":"hotspots","output":{"fields":[{"description":"Version of the output envelope format","name":"schemaVersion","optional":false,"type":"string"},{"description":"Name of the executed command","name":"command","optional":false,"type":"string"},{"description":"Execution status indicator","name":"status","optional":false,"type":"string"}],"mimeType":"application/json"}},{"description":"Ingest JSONL trace events from stdin or file","modes":[{"description":"Read JSONL events from stdin","flag":"--stdin","name":"stdin"},{"description":"Read JSONL events from PATH","flag":"--file","name":"file","value":"PATH"}],"name":"record","output":{"fields":[{"description":"Name of the executed command (always \"record\")","name":"command","optional":false,"type":"string"},{"description":"Version of the output envelope format","name":"schemaVersion","optional":false,"type":"string"},{"description":"Count of accepted events","name":"accepted","optional":false,"type":"number"},{"description":"Count of rejected non-empty lines","name":"rejected","optional":false,"type":"number"}],"mimeType":"application/json"},"stderr":{"description":"One JSON object per rejected non-empty line","fields":[{"description":"1‑based physical line number","name":"line","optional":false,"type":"number"},{"description":"Failing field/path when available","name":"field","optional":true,"type":"string|null"},{"description":"Human-readable rejection reason","name":"reason","optional":false,"type":"string"}],"mimeType":"application/jsonl"}},{"arguments":[{"description":"Agent harness name (claude-code or pi)","flag":"--agent","name":"agent","required":true,"type":"string"}],"description":"Install scryrs trace hook for a supported agent harness","name":"init","output":{"description":"Post-install