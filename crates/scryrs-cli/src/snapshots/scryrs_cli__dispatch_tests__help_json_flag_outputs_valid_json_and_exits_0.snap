{"binary":"scryrs","commands":[{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"}],"description":"Discover and analyze knowledge hotspots in a repository","name":"hotspots","output":{"fields":[{"description":"Version of the hotspot report output format (independent of trace event version)","name":"schemaVersion","optional":false,"type":"string"},{"description":"Name of the executed command","name":"command","optional":false,"type":"string"},{"description":"Resolved absolute path to the repository root","name":"repositoryPath","optional":false,"type":"string"},{"description":"Resolved absolute path to .scryrs/scryrs.db","name":"storePath","optional":false,"type":"string"},{"description":"Deterministic metadata from store state (storeSchemaVersion, analyzedEventCount, analyzedSubjectCount, firstEventId, lastEventId)","name":"runMetadata","optional":false,"type":"object"},{"description":"ISO 8601 wall-clock timestamp","name":"generatedAt","optional":false,"type":"string"},{"description":"Array of ranked HotspotEntry objects (empty for stores with no subject-bearing events)","name":"entries","optional":false,"type":"array"}],"mimeType":"application/json"}},{"description":"Ingest JSONL trace events from stdin or file. Defaults to local mode (writes to .scryrs/scryrs.db). Activates remote mode when a non-empty ingest URL is configured via scryrs.json `remote` section (overridden by SCRYRS_REMOTE_INGEST_URL, SCRYRS_REPOSITORY_ID, SCRYRS_WORKSPACE_ID, SCRYRS_AGENT_ID, SCRYRS_REMOTE_TIMEOUT_MS). Remote mode skips local SQLite and submits a single batch to POST /v1/trace-events/batch.","modes":[{"description":"Read JSONL events from stdin","flag":"--stdin","name":"stdin"},{"description":"Read JSONL events from PATH","flag":"--file","name":"file","value":"PATH"}],"name":"record","stderr":{"description":"One JSON object per rejected non-empty line (local) or per server-rejected item (remote, with line -1 and producer_event_id as the field)","fields":[{"description":"1‑based physical line number (-1 for server-rejected items)","name":"line","optional":false,"type":"number"},{"description":"Failing field/path when available, or producer_event_id for server rejects","name":"field","optional":true,"type":"string|null"},{"description":"Human-readable rejection reason","name":"reason","optional":false,"type":"string"}],"mimeType":"application/jsonl"},"transport":{"local":{"description":"Default transport — persists accepted events to .scryrs/scryrs.db via the canonical EventStore.","output":{"fields":[{"description":"Name of the executed command (always \"record\")","name":"command","optional":false,"type":"string"},{"description":"Version of the output envelope format","name":"schemaVersion","optional":false,"type":"string"},{"description":"Count of accepted events","name":"accepted","optional":false,"type":"number"},{"description":"Count of rejected non-empty lines","name":"rejected","optional":false,"type":"number"}],"mimeType":"application/json"}},"remote":{"configPrecedence":["1. Environment variables (SCRYRS_REMOTE_*)","2. scryrs.json `remote` section","3. Git remote origin URL (repository_id fallback only)"],"description":"Explicit remote mode — activated by scryrs.json `remote.ingest_url` or SCRYRS_REMOTE_INGEST_URL. Skips .scryrs/scryrs.db entirely. Default timeout 3000 ms.","output":{"fields":[{"description":"Name of the executed command (always \"record\")","name":"command","optional":false,"type":"string"},{"description":"Version of the output envelope format","name":"schemaVersion","optional":false,"type":"string"},{"description":"Always \"remote\" when remote mode is active","name":"transport","optional":false,"type":"string"},{"description":"Count of events the server accepted","name":"accepted","optional":false,"type":"number"},{"description":"Count of idempotent (previously seen) events — non-fatal","name":"duplicate","optional":false,"type":"number"},{"description":"Count of rejected events (local validation + server rejections)","name":"rejected","optional":false,"type":"number"},{"description":"Count of server-rejected items","name":"failed","optional":false,"type":"number"}],"mimeType":"application/json"},"requiredIdentity":["repository_id","workspace_id","agent_id"]}}},{"arguments":[{"description":"Harness whose native event is being translated","name":"harness","required":true,"type":"string","values":["claude-code","pi"]}],"description":"Translate a harness's native tool event and record it (harness integration entry point; fail-open)","failOpen":true,"modes":[{"description":"Read the harness event from stdin (default; used by Claude Code)","flag":"--stdin","name":"stdin"},{"description":"Read the harness event from PATH (used by the Pi shim)","flag":"--file","name":"file","value":"PATH"}],"name":"hook","output":{"description":"Writes nothing to stdout and always exits 0 (fail-open). Errors are appended to .scryrs/hooks/<harness>-warnings.log; the harness is never blocked.","mimeType":"none"}},{"arguments":[{"description":"Agent harness name (claude-code or pi)","flag":"--agent","name":"agent","required":true,"type":"string"},{"default":"local","description":"Install mode: local for SQLite trace store, live for remote ingest via scryrs server","flag":"--mode","name":"mode","type":"string","values":["local","live"]},{"description":"Live-mode remote ingest URL (required with --mode live)","flag":"--ingest-url","name":"ingest-url","type":"string"},{"description":"Live-mode workspace identity (required with --mode live)","flag":"--workspace-id","name":"workspace-id","type":"string"},{"description":"Live-mode agent identity (required with --mode live)","flag":"--agent-id","name":"agent-id","type":"string"},{"description":"Live-mode repository identity (derived from Git remote origin if omitted)","flag":"--repository-id","name":"repository-id","type":"string"}],"description":"Install scryrs trace hook for a supported agent harness","name":"init","output":{"description":"Post-install next-step instructions on stdout. Errors on stderr.","mimeType":"text/plain"}},{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"}],"description":"Generate reviewable knowledge proposals from hotspot and graph evidence","name":"propose","output":{"description":"Validated ProposalDocument JSON files written to .scryrs/proposals/. Count written to stdout. Errors on stderr.","mimeType":"application/json"}},{"description":"Review proposal inbox artifacts without mutating source-of-truth surfaces","name":"proposals","subcommands":[{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"}],"description":"Emit deterministic JSON rows for pending, accepted, and rejected proposal states","flags":[{"default":"all","description":"Optional proposal state filter","long":"--state","name":"state","type":"string","values":["pending","accepted","rejected","all"]}],"name":"list","output":{"fields":[{"description":"Deterministic proposal identifier","name":"proposalId","optional":false,"type":"string"},{"description":"Reviewer-facing proposal title","name":"title","optional":false,"type":"string"},{"description":"Proposal target kind","name":"targetType","optional":false,"type":"string"},{"description":"RFC 3339 proposal creation timestamp","name":"createdAt","optional":false,"type":"string"},{"description":"Current review state: pending, accepted, or rejected","name":"state","optional":false,"type":"string"}],"mimeType":"application/json"}},{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"},{"description":"Proposal identifier to review","name":"ID","required":true,"type":"string"}],"description":"Write a deterministic accepted ProposalReviewDecision under .scryrs/accepted/","flags":[{"description":"Reviewer identity","long":"--reviewer","name":"reviewer","required":true,"type":"string"},{"description":"Non-empty review rationale","long":"--rationale","name":"rationale","required":true,"type":"string"},{"description":"Explicit RFC 3339 review timestamp","long":"--decided-at","name":"decided-at","required":true,"type":"string"}],"name":"accept","output":{"description":"Writes .scryrs/accepted/{proposalId}.json on success and preserves .scryrs/proposals/{proposalId}.json unchanged.","mimeType":"none"}},{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"},{"description":"Proposal identifier to review","name":"ID","required":true,"type":"string"}],"description":"Write a deterministic rejected ProposalReviewDecision under .scryrs/rejected/","flags":[{"description":"Reviewer identity","long":"--reviewer","name":"reviewer","required":true,"type":"string"},{"description":"Non-empty review rationale","long":"--rationale","name":"rationale","required":true,"type":"string"},{"description":"Explicit RFC 3339 review timestamp","long":"--decided-at","name":"decided-at","required":true,"type":"string"}],"name":"reject","output":{"description":"Writes .scryrs/rejected/{proposalId}.json on success and preserves .scryrs/proposals/{proposalId}.json unchanged.","mimeType":"none"}}]},{"description":"Start local dashboard server and open the browser dashboard","flags":[{"default":8080,"description":"TCP port to bind","long":"--port","name":"port","short":"-p","type":"number"},{"default":"127.0.0.1","description":"Bind address","long":"--bind","name":"bind","short":"-b","type":"string"},{"default":false,"description":"Do not open browser automatically","long":"--no-open","name":"no-open","type":"boolean"},{"default":false,"description":"Serve from filesystem instead of embedded assets","long":"--dev","name":"dev","type":"boolean"}],"name":"dashboard","output":{"description":"Vue.js SPA served over HTTP. REST API at GET /api/hotspots, GET /api/sessions, GET /api/sessions/:sessionId, GET /api/events.","mimeType":"text/html"}},{"description":"Start the central trace ingest server with live hotspot query and signal streaming endpoints","endpoints":[{"description":"Ingest trace event batches with idempotent first-writer-wins semantics","method":"POST","path":"/v1/trace-events/batch"},{"description":"Query live hotspot rankings from server-owned state; supports ?window=cumulative and optional ?session_id","method":"GET","path":"/v1/repositories/{repository_id}/hotspots"},{"description":"Server-Sent Events stream of HotspotSignal records; supports ?after=<signal_id> cursor replay/resume","method":"GET","path":"/v1/repositories/{repository_id}/signals"}],"flags":[{"default":8081,"description":"TCP port to bind","long":"--port","name":"port","short":"-p","type":"number"},{"default":"127.0.0.1","description":"Bind address","long":"--bind","name":"bind","short":"-b","type":"string"},{"default":".scryrs/server.db","description":"Server-owned SQLite store path","long":"--store","name":"store","type":"string"}],"name":"server","output":{"description":"BatchIngestResponse returned by POST /v1/trace-events/batch. LiveHotspotsResponse returned by GET .../hotspots. text/event-stream returned by GET .../signals.","mimeType":"application/json"}},{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"}],"description":"Build a repository knowledge graph from hotspot evidence and docs structure","name":"graph","output":{"description":"Single-line KnowledgeGraphDocument JSON written to stdout. Also persisted to .scryrs/graph.json.","mimeType":"application/json"}},{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"}],"description":"Generate the route manifest from a knowledge graph artifact","name":"route","output":{"description":"Single-line RouteManifestDocument JSON written to stdout. Also persisted to .scryrs/routes.json.","mimeType":"application/json"}}],"exitCodes":{"0":"Success (hotspots: JSON written, including empty entries; record local: all events accepted; record remote: no rejections or failures; init: hook installed; propose/proposals: artifacts written or listed successfully; dashboard: server shut down cleanly; server: server shut down cleanly; hook: always — fail-open, never blocks the harness)","1":"Hotspots: storage error. Record: one or more events rejected (local or server), or I/O error writing output. Init: I/O error. Proposals: serialization or filesystem write failure. Dashboard: port in use or artifact read error. Server: port in use or store error.","2":"Usage error; hotspots: missing/unsupported store; record: also fatal I/O error (unreadable file, store failure, missing remote identity, transport timeout, connection failure, non-2xx response, malformed response); init: unsupported harness, collision, self-install refusal, invalid mode, or missing/invalid live-mode configuration; proposals: invalid filter, invalid proposal/review document, unknown proposal ID, or conflicting terminal review state; dashboard: invalid flags; server: invalid flags or bind failure."},"globalFlags":[{"action":"help","description":"Print help message and exit","long":"--help","name":"help","short":"-h"},{"action":"version","description":"Print version and exit","long":"--version","name":"version","short":"-V"},{"action":"helpJson","description":"Print machine-readable CLI surface description and exit","long":"--help-json","name":"help-json","short":"-hj"}],"rootBehavior":{"action":"help","exitCode":0},"surfaceVersion":"0.9.0"}
