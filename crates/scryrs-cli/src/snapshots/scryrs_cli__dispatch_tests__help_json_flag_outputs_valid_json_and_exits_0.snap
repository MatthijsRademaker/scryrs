{"binary":"scryrs","commands":[{"arguments":[{"description":"Path to the repository root directory","name":"PATH","required":true,"type":"string"}],"description":"Discover and analyze knowledge hotspots in a repository","name":"hotspots","output":{"fields":[{"description":"Version of the hotspot report output format (independent of trace event version)","name":"schemaVersion","optional":false,"type":"string"},{"description":"Name of the executed command","name":"command","optional":false,"type":"string"},{"description":"Resolved absolute path to the repository root","name":"repositoryPath","optional":false,"type":"string"},{"description":"Resolved absolute path to .scryrs/scryrs.db","name":"storePath","optional":false,"type":"string"},{"description":"Deterministic metadata from store state (storeSchemaVersion, analyzedEventCount, analyzedSubjectCount, firstEventId, lastEventId)","name":"runMetadata","optional":false,"type":"object"},{"description":"ISO 8601 wall-clock timestamp","name":"generatedAt","optional":false,"type":"string"},{"description":"Array of ranked HotspotEntry objects (empty for stores with no subject-bearing events)","name":"entries","optional":false,"type":"array"}],"mimeType":"application/json"}},{"description":"Ingest JSONL trace events from stdin or file","modes":[{"description":"Read JSONL events from stdin","flag":"--stdin","name":"stdin"},{"description":"Read JSONL events from PATH","flag":"--file","name":"file","value":"PATH"}],"name":"record","output":{"fields":[{"description":"Name of the executed command (always \"record\")","name":"command","optional":false,"type":"string"},{"description":"Version of the output envelope format","name":"schemaVersion","optional":false,"type":"string"},{"description":"Count of accepted events","name":"accepted","optional":false,"type":"number"},{"description":"Count of rejected non-empty lines","name":"rejected","optional":false,"type":"number"}],"mimeType":"application/json"},"stderr":{"description":"One JSON object per rejected non-empty line","fields":[{"description":"1‑based physical line number","name":"line","optional":false,"type":"number"},{"description":"Failing field/path when available","name":"field","optional":true,"type":"string|null"},{"description":"Human-readable rejection reason","name":"reason","optional":false,"type":"string"}],"mimeType":"application/jsonl"}},{"arguments":[{"description":"Agent harness name (claude-code or pi)","flag":"--agent","name":"agent","required":true,"type":"string"}],"description":"Install scryrs trace hook for a supported agent harness","name":"init","output":{"description":"Post-install next-step instructions on stdout. Errors on stderr.","mimeType":"text/plain"}},{"description":"Start local dashboard server (Phase 3 — planned, not yet implemented)","flags":[{"default":8080,"description":"TCP port to bind","long":"--port","name":"port","short":"-p","type":"number"},{"default":"127.0.0.1","description":"Bind address","long":"--bind","name":"bind","short":"-b","type":"string"},{"default":false,"description":"Do not open browser automatically","long":"--no-open","name":"no-open","type":"boolean"},{"default":false,"description":"Serve from filesystem instead of embedded assets","long":"--dev","name":"dev","type":"boolean"}],"name":"dashboard","output":{"description":"Vue.js SPA served over HTTP. REST API at GET /api/hotspots, GET /api/sessions, GET /api/events.","mimeType":"text/html"},"status":"planned"}],"exitCodes":{"0":"Success (hotspots: JSON written, including empty entries; record: all events accepted; init: hook installed; dashboard: server shut down cleanly)","1":"Hotspots: storage error. Record: one or more events rejected, or I/O error writing output. Init: I/O error. Dashboard: port in use or artifact read error.","2":"Usage error; hotspots: missing/unsupported store; record: also fatal I/O error (unreadable file or store failure); init: unsupported harness, collision, or self-install refusal; dashboard: not yet implemented (Phase 3)"},"globalFlags":[{"action":"help","description":"Print help message and exit","long":"--help","name":"help","short":"-h"},{"action":"version","description":"Print version and exit","long":"--version","name":"version","short":"-V"},{"action":"helpJson","description":"Print machine-readable CLI surface description and exit","long":"--help-json","name":"help-json","short":"-hj"}],"rootBehavior":{"action":"help","exitCode":0},"surfaceVersion":"0.4.0"}
