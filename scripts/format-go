#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT/scripts/.versions"
source "$ROOT/scripts/lib/docker-verification.sh"

verification_reset
verification_run_as_root
verification_workdir /workspace/src
verification_add_cache go-build /cache/go-build GOCACHE
verification_add_cache go-mod /cache/go-mod GOMODCACHE
verification_add_env HOME=/tmp
verification_add_env GOFUMPT_VERSION="$GOFUMPT_VERSION"
verification_add_env GOIMPORTS_VERSION="$GOIMPORTS_VERSION"
verification_add_env GCI_VERSION="$GCI_VERSION"

verification_run_container "$GO_IMAGE" sh -ceu '
apk add --no-cache git util-linux >/dev/null
export GOBIN=/tmp/go-bin
export PATH="$GOBIN:$PATH"
mkdir -p "$GOBIN"
go install mvdan.cc/gofumpt@"$GOFUMPT_VERSION"
go install golang.org/x/tools/cmd/goimports@"$GOIMPORTS_VERSION"
go install github.com/daixiang0/gci@"$GCI_VERSION"

gofumpt_out="$(gofumpt -l .)"
goimports_out="$(goimports -l .)"
gci_out="$(gci list --skip-generated --custom-order -s standard -s default -s prefix\(github.com/matthijsrademaker/swarm\) .)"

if [ -n "$gofumpt_out" ]; then
  printf "[gofumpt]\n%s\n" "$gofumpt_out"
fi
if [ -n "$goimports_out" ]; then
  printf "[goimports]\n%s\n" "$goimports_out"
fi
if [ -n "$gci_out" ]; then
  printf "[gci]\n%s\n" "$gci_out"
fi

if [ -n "$gofumpt_out$goimports_out$gci_out" ]; then
  echo "Go formatting/import checks failed"
  exit 1
fi

echo "Go formatting/import checks passed"
'
