#!/usr/bin/env bash
# Run Rust static checks inside a Docker container.
# No host Rust toolchain required — works on swarm worker agents via DinD.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/docker-verification.sh"

step "cargo fmt --all --check"
run_rust cargo fmt --all --check

step "cargo check --workspace --all-targets --all-features --locked"
run_rust cargo check --workspace --all-targets --all-features --locked

step "cargo clippy --workspace --all-targets --all-features --locked -- -D warnings"
run_rust cargo clippy --workspace --all-targets --all-features --locked -- -D warnings
