#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT/scripts/.versions"
source "$ROOT/scripts/lib/docker-verification.sh"

verification_reset
verification_run_as_root
verification_workdir /workspace/src
verification_add_cache go-build /cache/go-build GOCACHE
verification_add_cache go-mod /cache/go-mod GOMODCACHE
verification_add_env HOME=/tmp
verification_add_env GOVULNCHECK_VERSION="$GOVULNCHECK_VERSION"

verification_run_container "$GO_IMAGE" sh -ceu '
apk add --no-cache jq >/dev/null
export GOBIN=/tmp/go-bin
export PATH="$GOBIN:$PATH"
mkdir -p "$GOBIN"
go install golang.org/x/vuln/cmd/govulncheck@"$GOVULNCHECK_VERSION"

json_file="$(mktemp)"
status=0
govulncheck -json ./... >"$json_file" || status=$?
cat "$json_file"
findings="$(jq -s "map(select(has(\"finding\"))) | length" "$json_file" 2>/dev/null || echo 0)"
if [ "$status" -ne 0 ]; then
  echo "govulncheck reported ${findings} finding event(s)"
  exit "$status"
fi
echo "govulncheck passed with ${findings} finding event(s)"
'
