#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT/scripts/.versions"
source "$ROOT/scripts/lib/docker-verification.sh"

verification_reset
verification_workdir /workspace/src/dashboard
verification_add_cache npm /cache/npm npm_config_cache

verification_run_container "$NODE_IMAGE" sh -ceu '
npm ci --silent >/dev/null
json_file="$(mktemp)"
status=0
npm audit --json --omit=dev --audit-level=high >"$json_file" || status=$?
cat "$json_file"
node - "$json_file" <<"NODE"
const fs = require("fs");
const data = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const vulnerabilities = data.metadata?.vulnerabilities ?? {};
const high = vulnerabilities.high ?? 0;
const critical = vulnerabilities.critical ?? 0;
console.log(`npm audit high=${high} critical=${critical}`);
NODE
exit "$status"
'
