#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT/scripts/.versions"
source "$ROOT/scripts/lib/docker-verification.sh"

lint_base_ref="${GO_LINT_NEW_FROM_REV:-}"
if [ -z "$lint_base_ref" ]; then
  lint_base_ref="$(git -C "$ROOT" merge-base HEAD origin/main 2>/dev/null || git -C "$ROOT" rev-parse HEAD~1 2>/dev/null || true)"
fi

verification_reset
verification_run_as_root
verification_workdir /workspace/src
verification_add_cache go-build /cache/go-build GOCACHE
verification_add_cache go-mod /cache/go-mod GOMODCACHE
verification_add_env HOME=/tmp
verification_add_env GO_LINT_NEW_FROM_REV="$lint_base_ref"

verification_run_container "$GOLANGCI_LINT_IMAGE" sh -ceu '
apk add --no-cache jq >/dev/null
json_file="$(mktemp)"
status=0
if [ -n "${GO_LINT_NEW_FROM_REV:-}" ]; then
  golangci-lint run --config /workspace/.golangci.yml --output.json.path "$json_file" --new-from-rev "$GO_LINT_NEW_FROM_REV" ./... || status=$?
else
  golangci-lint run --config /workspace/.golangci.yml --output.json.path "$json_file" ./... || status=$?
fi
cat "$json_file"
issues="$(jq ".Issues | length" "$json_file" 2>/dev/null || echo 0)"
if [ "$status" -ne 0 ]; then
  echo "golangci-lint found ${issues} issue(s)"
  exit "$status"
fi
echo "golangci-lint passed with ${issues} issue(s)"
'
