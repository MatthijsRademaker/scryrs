#!/usr/bin/env bash
# Run Rust security checks inside a Docker container.
# No host Rust toolchain required — works on swarm worker agents via DinD.
# Uses a newer Rust image for security tools (advisory DB needs CVSS 4.0 support).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/docker-verification.sh"

ensure_cargo_tool cargo-deny
ensure_cargo_tool cargo-audit

step "cargo deny check"
run_rust --image "$SECURITY_RUST_IMAGE" -- cargo deny check

step "cargo audit"
run_rust --image "$SECURITY_RUST_IMAGE" -- cargo audit
