#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo not found; install Rust toolchain from rust-toolchain.toml" >&2
  exit 127
fi

if ! command -v cargo-deny >/dev/null 2>&1; then
  echo "cargo-deny not found; install with: cargo install --locked cargo-deny" >&2
  exit 127
fi

if ! command -v cargo-audit >/dev/null 2>&1; then
  echo "cargo-audit not found; install with: cargo install --locked cargo-audit" >&2
  exit 127
fi

cargo deny check
cargo audit
