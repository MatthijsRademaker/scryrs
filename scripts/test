#!/usr/bin/env bash
# Run Rust tests inside a Docker container.
# No host Rust toolchain required — works on swarm worker agents via DinD.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/docker-verification.sh"

step "cargo test --workspace --all-targets --all-features --locked"
run_rust cargo test --workspace --all-targets --all-features --locked
