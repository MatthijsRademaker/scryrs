#!/usr/bin/env bash
# Cross-harness end-to-end verification entrypoint.
#
# Runtime measurement (2026-06-21, CI-like DinD environment):
#   ~41 seconds with cached cargo build (binary already compiled)
#   Estimated <3 minutes without cache (clean checkout, fresh Docker images)
#
# CI lane assignment: NIGHTLY (conservative starting point).
#   The measured wall-clock time is well under the 3-minute PR-gate threshold,
#   but Docker-in-Docker adds operational overhead (image pulls, DIND socket
#   availability). If CI gains stable DIND support, this can be promoted to a
#   path-triggered PR check (on hooks/** changes).
#
# Builds the real scryrs binary via Docker (Rust container) and drives both
# Claude Code and Pi hook fixtures against it (Node container). Run this to
# prove that reference hooks correctly feed real scryrs persistence without
# changing agent-visible behavior. Claude Code uses `record --stdin`; Pi uses
# `record --file <PATH>` because Pi exec opens stdin as /dev/null.
#
# Uses node:22 (Debian-based, glibc) so the Rust-compiled scryrs binary runs
# without recompilation for musl.
#
# Usage:
#   scripts/verify-trace-capture              # run all fixtures
#   scripts/verify-trace-capture --claude-only  # Claude Code only
#   scripts/verify-trace-capture --pi-only       # Pi source-hook + real Pi-process installed-hook
#   scripts/verify-trace-capture --init-only     # installed-hook e2e only
#
# Prerequisites:
#   - Docker (host or DinD)
#   - No host Node.js required
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DOCKER_LIB="$ROOT/scripts/lib/docker-verification.sh"

if [[ ! -f "$DOCKER_LIB" ]]; then
	echo "ERROR: docker-verification.sh not found at $DOCKER_LIB" >&2
	exit 2
fi

# shellcheck source=scripts/lib/docker-verification.sh
source "$DOCKER_LIB"

RUN_CLAUDE=true
RUN_PI=true
RUN_INIT=true
INIT_ONLY=false
CLAUDE_ONLY=false
PI_ONLY=false

while [[ $# -gt 0 ]]; do
	case "$1" in
		--claude-only)
			CLAUDE_ONLY=true
			shift
			;;
		--pi-only)
			PI_ONLY=true
			shift
			;;
		--init-only)
			INIT_ONLY=true
			shift
			;;
		*)
			echo "ERROR: unknown flag: $1" >&2
			echo "Usage: scripts/verify-trace-capture [--claude-only|--pi-only|--init-only]" >&2
			exit 2
			;;
	esac
done

# --- mutually-exclusive flag enforcement ---
FLAG_COUNT=0
$CLAUDE_ONLY && FLAG_COUNT=$((FLAG_COUNT + 1))
$PI_ONLY && FLAG_COUNT=$((FLAG_COUNT + 1))
$INIT_ONLY && FLAG_COUNT=$((FLAG_COUNT + 1))

if [[ $FLAG_COUNT -gt 1 ]]; then
	echo "ERROR: --claude-only, --pi-only, and --init-only are mutually exclusive" >&2
	exit 2
fi

if $CLAUDE_ONLY; then
	RUN_CLAUDE=true
	RUN_PI=false
	RUN_INIT=false
elif $PI_ONLY; then
	RUN_CLAUDE=false
	RUN_PI=true
	RUN_INIT=true
elif $INIT_ONLY; then
	RUN_CLAUDE=false
	RUN_PI=false
	RUN_INIT=true
fi

# ---------------------------------------------------------------------------
# 1. Build scryrs binary (needed by both fixtures)
# ---------------------------------------------------------------------------
step "Building scryrs binary (cargo build --release)"
run_rust bash -c 'cargo build --release && mkdir -p /workspace/.docker-fixtures && cp /workspace/target/release/scryrs /workspace/.docker-fixtures/scryrs'

# Verify the binary exists
SCYRRS_BIN="$ROOT/.docker-fixtures/scryrs"
if [[ ! -x "$SCYRRS_BIN" ]]; then
	echo "ERROR: scryrs binary not found at $SCYRRS_BIN after build" >&2
	exit 1
fi
echo "  scryrs binary built at .docker-fixtures/scryrs"

CLAUDE_EXIT=0
PI_EXIT=0
INIT_EXIT=0

# Use node:22 (Debian-based, glibc) because scryrs is compiled on rust:1.85.0
# which also uses glibc. Alpine-based node images use musl and won't run the binary.
FIXTURE_NODE_IMAGE="${FIXTURE_NODE_IMAGE:-node:22}"

# Pre-install better-sqlite3 in the workspace so both fixtures can import it.
step "Installing better-sqlite3 for fixture use"
run_node --image "$FIXTURE_NODE_IMAGE" \
    -- \
    npm install better-sqlite3 \
    || { echo "ERROR: failed to install better-sqlite3" >&2; exit 1; }

# ---------------------------------------------------------------------------
# 2. Claude Code fixture
# ---------------------------------------------------------------------------
if $RUN_CLAUDE; then
	step "Running Claude Code E2E fixture"
	run_node --image "$FIXTURE_NODE_IMAGE" \
		-e "PATH=/workspace/.docker-fixtures:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
		-e "SCRYRS_BIN=/workspace/.docker-fixtures/scryrs" \
		-- \
		node /workspace/scripts/verification/claude-code-e2e.mjs \
		|| CLAUDE_EXIT=$?
	if [[ $CLAUDE_EXIT -eq 0 ]]; then
		echo "  Claude Code fixture: PASSED"
	else
		echo "  Claude Code fixture: FAILED (exit $CLAUDE_EXIT)" >&2
	fi
fi

# ---------------------------------------------------------------------------
# 3. Pi fixture
# ---------------------------------------------------------------------------
if $RUN_PI; then
	step "Running Pi E2E fixture"
	run_node --image "$FIXTURE_NODE_IMAGE" \
		-e "PATH=/workspace/.docker-fixtures:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
		-e "SCRYRS_BIN=/workspace/.docker-fixtures/scryrs" \
		-- \
		node /workspace/scripts/verification/pi-hook-e2e.mjs \
		|| PI_EXIT=$?
	if [[ $PI_EXIT -eq 0 ]]; then
		echo "  Pi fixture: PASSED"
	else
		echo "  Pi fixture: FAILED (exit $PI_EXIT)" >&2
	fi
fi

# ---------------------------------------------------------------------------
# 4. Installed-hook e2e fixture
# ---------------------------------------------------------------------------
if $RUN_INIT; then
	step "Running installed-hook E2E fixture"
	INIT_ARGS=()
	if $PI_ONLY; then
		INIT_ARGS+=(--pi-only)
	fi
	if $CLAUDE_ONLY; then
		INIT_ARGS+=(--claude-only)
	fi
	run_node --image "$FIXTURE_NODE_IMAGE" \
		-e "PATH=/workspace/.docker-fixtures:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
		-e "SCRYRS_BIN=/workspace/.docker-fixtures/scryrs" \
		-- \
		node /workspace/scripts/verification/installed-hook-e2e.mjs "${INIT_ARGS[@]}" \
		|| INIT_EXIT=$?
	if [[ $INIT_EXIT -eq 0 ]]; then
		echo "  Installed-hook fixture: PASSED"
	else
		echo "  Installed-hook fixture: FAILED (exit $INIT_EXIT)" >&2
	fi
fi

# ---------------------------------------------------------------------------
# 5. Summary
# ---------------------------------------------------------------------------
echo ""
echo "============================================"
echo "Cross-harness verification summary"
echo "============================================"

if $RUN_CLAUDE; then
	if [[ $CLAUDE_EXIT -eq 0 ]]; then
		echo "  Claude Code: PASSED"
	else
		echo "  Claude Code: FAILED"
	fi
fi

if $RUN_PI; then
	if [[ $PI_EXIT -eq 0 ]]; then
		echo "  Pi:          PASSED"
	else
		echo "  Pi:          FAILED"
	fi
fi

if $RUN_INIT; then
	if [[ $INIT_EXIT -eq 0 ]]; then
		echo "  Init hooks:  PASSED"
	else
		echo "  Init hooks:  FAILED"
	fi
fi

echo "============================================"

ALL_EXIT=$((CLAUDE_EXIT + PI_EXIT + INIT_EXIT))
if [[ $ALL_EXIT -ne 0 ]]; then
	if $RUN_CLAUDE && [[ $CLAUDE_EXIT -ne 0 ]]; then
		echo "Run with --claude-only to debug the Claude Code fixture." >&2
	fi
	if $RUN_PI && [[ $PI_EXIT -ne 0 ]]; then
		echo "Run with --pi-only to debug the Pi fixture." >&2
	fi
	if $RUN_INIT && [[ $INIT_EXIT -ne 0 ]]; then
		echo "Run with --init-only to debug the installed-hook fixture." >&2
	fi
	exit 1
fi

exit 0
