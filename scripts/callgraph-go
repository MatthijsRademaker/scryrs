#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT/scripts/.versions"
source "$ROOT/scripts/lib/docker-verification.sh"

OUTPUT_REL="${GO_CALLGRAPH_OUTPUT:-.cache/verification-artifacts/backend-callgraph.svg}"
OUTPUT_ABS="$ROOT/$OUTPUT_REL"
mkdir -p "$(dirname "$OUTPUT_ABS")"

verification_reset
verification_run_as_root
verification_workdir /workspace/src
verification_add_cache go-build /cache/go-build GOCACHE
verification_add_cache go-mod /cache/go-mod GOMODCACHE
verification_add_env HOST_UID="$(verification_workspace_uid)"
verification_add_env HOST_GID="$(verification_workspace_gid)"
verification_add_env HOME=/tmp
verification_add_env GO_CALLVIS_VERSION="$GO_CALLVIS_VERSION"
verification_add_env GO_CALLGRAPH_OUTPUT="/workspace/$OUTPUT_REL"

verification_run_container "$GO_IMAGE" sh -ceu '
apk add --no-cache util-linux >/dev/null
export GOBIN=/tmp/go-bin
export PATH="$GOBIN:$PATH"
mkdir -p "$GOBIN"
go install github.com/ofabry/go-callvis@"$GO_CALLVIS_VERSION"
mkdir -p "$(dirname "$GO_CALLGRAPH_OUTPUT")"
exec setpriv --reuid "$HOST_UID" --regid "$HOST_GID" --groups "$HOST_GID",0 \
  go-callvis -file "$GO_CALLGRAPH_OUTPUT" -format svg -focus github.com/matthijsrademaker/swarm ./...
'

echo "go-callvis artifact: $OUTPUT_REL"
